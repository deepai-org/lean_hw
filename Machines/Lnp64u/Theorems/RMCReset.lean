/-- The register names (computed against the golden manifest; the names do
not depend on the manifest, see `names_stable`). -/
private def nameList : List String := (regDecls demoManifest).map (·.name)

set_option maxRecDepth 100000 in
set_option maxHeartbeats 4000000 in
/-- The names are manifest-independent (definitional). -/
private theorem names_stable (m : Manifest) :
    (regDecls m).map (·.name) = nameList := rfl

set_option maxRecDepth 100000 in
set_option maxHeartbeats 4000000 in
/-- The names' keys, as computed (kernel-reduced, no string comparisons). -/
private theorem keys_eq : nameList.map skey = keyLit := by decide +kernel

set_option maxRecDepth 100000 in
set_option maxHeartbeats 4000000 in
private theorem keyLit_nodup : keyLit.Nodup := by decide

/-- The 825 register names are pairwise distinct. -/
theorem names_nodup (m : Manifest) : ((regDecls m).map (·.name)).Nodup := by
  rw [names_stable]
  have h : (nameList.map skey).Nodup := keys_eq ▸ keyLit_nodup
  exact (List.pairwise_map.mp h).imp fun hne heq => hne (congrArg skey heq)

set_option maxRecDepth 100000 in
set_option maxHeartbeats 1000000 in
theorem regDecls_length (m : Manifest) : (regDecls m).length = 825 := rfl

/-! ## Fold lookups -/

/-- A fold of `RegEnv.set`s over decls avoiding `n` does not touch `n`. -/
private theorem foldl_set_ne (l : List RegDecl) (ρ : RegEnv) {n : String} {w : Nat}
    (h : ∀ r ∈ l, r.name ≠ n) :
    (l.foldl (fun ρ r => ρ.set r.name r.init) ρ) n w = ρ n w := by
  induction l generalizing ρ with
  | nil => rfl
  | cons r t ih =>
      rw [List.foldl_cons, ih _ (fun x hx => h x (List.mem_cons_of_mem r hx))]
      have hr : n ≠ r.name := fun he => h r (List.mem_cons_self ..) he.symm
      simp [RegEnv.set, hr]

/-- Lookup through the reset fold: with pairwise-distinct names, register
`i`'s declared init wins at its declared width. -/
theorem foldl_set_get (l : List RegDecl) (hnd : (l.map (·.name)).Nodup)
    (ρ : RegEnv) (i : Nat) (hi : i < l.length) :
    (l.foldl (fun ρ r => ρ.set r.name r.init) ρ) l[i].name l[i].width
      = l[i].init := by
  induction l generalizing ρ i with
  | nil => simp at hi
  | cons r t ih =>
      rw [List.foldl_cons]
      rw [List.map_cons, List.nodup_cons] at hnd
      match i with
      | 0 =>
          have hnotin : ∀ x ∈ t, x.name ≠ r.name := fun x hx he =>
            hnd.1 (he ▸ List.mem_map_of_mem hx)
          show (t.foldl _ (ρ.set r.name r.init)) r.name r.width = r.init
          rw [foldl_set_ne t _ hnotin]
          simp [RegEnv.set]
      | i + 1 =>
          have hit : i < t.length := by simpa using hi
          show (t.foldl _ (ρ.set r.name r.init)) (t[i]'hit).name
              (t[i]'hit).width = (t[i]'hit).init
          exact ih hnd.2 _ i hit

set_option maxRecDepth 100000 in
set_option maxHeartbeats 2000000 in
/-- The reset register file, as the bare fold (definitional). -/
private theorem reset_regs_eq (m : Manifest) : (Hw.core m).reset.regs
    = (regDecls m).foldl (fun (ρ : RegEnv) r => ρ.set r.name r.init)
        (fun _ w => 0#w) := rfl

set_option maxRecDepth 100000 in
set_option maxHeartbeats 1000000 in
/-- The reset value of register `i` of the LNP64-µ core. The consumer
instantiates `i` with a literal; the register's name, width, and declared
reset value all reduce definitionally. -/
theorem reset_lookup (m : Manifest) (i : Nat) (hi : i < 825) :
    (Hw.core m).reset.regs ((regDecls m)[i]'(regDecls_length m ▸ hi)).name
        ((regDecls m)[i]'(regDecls_length m ▸ hi)).width
      = ((regDecls m)[i]'(regDecls_length m ▸ hi)).init := by
  rw [reset_regs_eq]
  exact foldl_set_get (regDecls m) (names_nodup m) _ i (regDecls_length m ▸ hi)

/-- The reset RAM is the boot image. -/
theorem reset_mem (m : Manifest) (a : Nat) :
    (Hw.core m).reset.mems "mem" a 32 = m.initState.mem (BitVec.ofNat 12 a) := by
  show (if "mem" = "mem" ∧ 32 = (memDecl m).dataWidth
        then ((memDecl m).init a).setWidth 32 else (0 : BitVec 32))
      = m.initState.mem (BitVec.ofNat 12 a)
  simp [memDecl, BitVec.setWidth_eq]
